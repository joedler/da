{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "types": ["google-apps-script"],
    "module": "none",
    "outFile": "build/Code.js",
    "strict": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
